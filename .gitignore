# ============================================
# HealthTrust — .gitignore
# ============================================

# ---- Sensitive / Secret files ----
*.mnemonic
*.key
.env
.env.local
.env.*.local
treasury-wallet/treasury.addr

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
package-lock.json
client/.vite/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
venv/
env/
*.egg-info/
.pytest_cache/

# ---- Go ----
*.exe
*.exe~
*.dll
*.so
*.dylib
automation-service/go.sum

# ---- ML Model artifacts (regenerate with export_model.py) ----
ml-service/models/*.pkl

# ---- Aiken build artifacts ----
aiken-contracts/build/
aiken-contracts/aiken.lock
aiken-contracts/.github/
aiken-contracts/plutus.json

# ---- Jupyter notebooks (use export_model.py instead) ----
*.ipynb

# ---- Default Vite boilerplate ----
client/public/vite.svg
client/src/assets/vue.svg
client/src/components/HelloWorld.vue

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Database ----
*.db
*.sqlite
*.sqlite3

# ---- Logs ----
*.log
logs/

# ---- Misc ----
*.bak
*.tmp
Wallet_pictures/

# ---- Private documentation (keep local, not public) ----
SUMMARY.md
passwords.md
DATABASE_REFERENCE.md
RUN_COMPLETE_SYSTEM.md
STARTUP_GUIDE.md
TESTING_GUIDE.md
SUMMARY2.md
